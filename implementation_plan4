## Proposed Changes

### 🗄️ Banco de Dados (Database Layer)

#### [MODIFY] [schema.prisma](file:///d:/Arquivos_Obsidian/ZenTriq/zentriq-api/prisma/schema.prisma)
- Adicionar os modelos `investments` (com o campo `ticker`) e `investment_history`.
- Adicionar relações correspondentes no modelo `users`.

```prisma
model investments {
  id              String               @id @default(auto()) @map("_id") @db.ObjectId
  user_id         String               @db.ObjectId
  name            String               // Ex: "CDB Inter 102%", "Ações Petrobras", "Tesouro IPCA 2029"
  type            String               // "fixed_income", "variable_income", "cripto", "others"
  ticker          String?              // Ex: "PETR4", "MXRF11", "BOVA11" (usado para cotação automática)
  institution     String               // Ex: "Inter", "XP", "NuInvest"
  invested_amount Float                // Valor original total investido
  current_amount  Float                // Valor atualizado de mercado/cotação
  purchase_date   String               // Data de aquisição/início (YYYY-MM-DD)
  created_at      String?              @default("datetime('now')")
  updated_at      String?
  users           users                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  history         investment_history[]
  @@index([user_id])
}

model investment_history {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  user_id       String      @db.ObjectId
  investment_id String      @db.ObjectId
  date          String      // Snapshot mensal (Formato "YYYY-MM")
  invested_val  Float       // Valor investido acumulado no mês
  current_val   Float       // Valor atualizado acumulado no mês
  created_at    String?     @default("datetime('now')")
  investments   investments @relation(fields: [investment_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([investment_id])
}
```

