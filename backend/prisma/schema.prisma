generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  phone     String    @unique @db.VarChar(20) // WhatsApp number
  name      String?   @db.VarChar(100)
  email     String?   @unique @db.VarChar(255)
  isActive  Boolean   @default(true)
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  transactions Transaction[]
  limits       BudgetLimit[]
  categories   Category[]
  messageLogs  MessageLog[]

  @@map("users")
  @@index([phone])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  color       String?   @db.VarChar(7)
  icon        String?   @db.VarChar(50)
  isDefault   Boolean   @default(false)
  
  userId      String    @db.Uuid @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  transactions Transaction[]
  limits       BudgetLimit[]

  @@unique([name, userId])
  @@map("categories")
  @@index([userId])
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  amount      Decimal           @db.Decimal(12, 2)
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)
  description String            @db.VarChar(255)
  date        DateTime          @default(now())
  
  categoryId  String            @db.Uuid @map("category_id")
  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  userId      String            @db.Uuid @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  @@map("transactions")
  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

model BudgetLimit {
  id         String    @id @default(uuid()) @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  period     String    @default("MONTHLY") @db.VarChar(20) // "MONTHLY", "WEEKLY", "YEARLY"
  
  categoryId String    @db.Uuid @map("category_id")
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  userId     String    @db.Uuid @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([categoryId, userId])
  @@map("budget_limits")
  @@index([userId])
}

model MessageLog {
  id        String   @id @default(uuid()) @db.Uuid
  from      String   @db.VarChar(20)
  text      String   @db.Text
  response  String?  @db.Text
  isImage   Boolean  @default(false)
  status    String   @default("PROCESSED") // "PROCESSED", "FAILED"
  
  userId    String?  @db.Uuid @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("message_logs")
  @@index([from])
  @@index([createdAt])
}

