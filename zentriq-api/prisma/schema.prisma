generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model accounts {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  user_id                String                   @db.ObjectId
  name                   String
  type                   String
  balance                Float?                   @default(0)
  initial_balance        Float?                   @default(0)
  color                  String?                  @default("#378ADD")
  icon                   String?                  @default("wallet")
  is_active              Int?                     @default(1)
  credit_limit           Float?
  closing_day            Int?
  due_day                Int?
  created_at             String?                  @default("datetime('now')")
  updated_at             String?
  users                  users                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recurring_transactions recurring_transactions[]
  transactions           transactions[]
  @@index([user_id])
}

model budgets {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  user_id      String     @db.ObjectId
  category_id  String     @db.ObjectId
  amount_limit Float
  month        Int
  year         Int
  created_at   String?    @default("datetime('now')")
  categories   categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category_id, month, year])
}

model categories {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  user_id                String                   @db.ObjectId
  name                   String
  type                   String
  color                  String?                  @default("#888780")
  icon                   String?                  @default("tag")
  is_default             Int?                     @default(0)
  parent_id              String?                  @db.ObjectId
  created_at             String?                  @default("datetime('now')")
  budgets                budgets[]
  categories             categories?              @relation("categoriesTocategories", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_categories       categories[]             @relation("categoriesTocategories")
  users                  users                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recurring_transactions recurring_transactions[]
  transactions           transactions[]
  @@index([user_id])
}

model goals {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  user_id        String  @db.ObjectId
  name           String
  target_amount  Float
  current_amount Float?  @default(0)
  deadline       String?
  color          String? @default("#1D9E75")
  icon           String? @default("target")
  is_completed   Int?    @default(0)
  completed_at   String?
  created_at     String? @default("datetime('now')")
  updated_at     String?
  users          users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model recurring_transactions {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  user_id       String         @db.ObjectId
  account_id    String         @db.ObjectId
  category_id   String?        @db.ObjectId
  type          String
  amount        Float
  description   String
  frequency     String
  start_date    String
  end_date      String?
  next_due_date String
  is_active     Int?           @default(1)
  created_at    String?        @default("datetime('now')")
  updated_at    String?
  categories    categories?    @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accounts      accounts       @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions  transactions[]
  @@index([user_id])
  @@index([next_due_date])
}

model refresh_tokens {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String  @db.ObjectId
  token      String  @unique
  expires_at String
  created_at String? @default("datetime('now')")
  users      users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model notifications {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String  @db.ObjectId
  title      String
  message    String
  type       String? @default("info")
  is_read    Int?    @default(0)
  created_at String? @default("datetime('now')")
  users      users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
}

model transactions {
  id                     String                  @id @default(auto()) @map("_id") @db.ObjectId
  user_id                String                  @db.ObjectId
  account_id             String                  @db.ObjectId
  category_id            String?                 @db.ObjectId
  type                   String
  amount                 Float
  description            String
  date                   String
  recurring_id           String?                 @db.ObjectId
  to_account_id          String?                 @db.ObjectId
  notes                  String?
  created_at             String?                 @default("datetime('now')")
  updated_at             String?
  recurring_transactions recurring_transactions? @relation(fields: [recurring_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories             categories?             @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accounts               accounts                @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                  users                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([account_id])
  @@index([date])
}

model users {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  email                  String                   @unique
  password_hash          String
  monthly_income         Float?                   @default(0)
  currency               String?                  @default("BRL")
  created_at             String?                  @default("datetime('now')")
  updated_at             String?
  gemini_api_key         String?
  accounts               accounts[]
  budgets                budgets[]
  categories             categories[]
  goals                  goals[]
  recurring_transactions recurring_transactions[]
  refresh_tokens         refresh_tokens[]
  transactions           transactions[]
  notifications          notifications[]
  investments            investments[]
  chat_messages          chat_messages[]
}

model investments {
  id              String               @id @default(auto()) @map("_id") @db.ObjectId
  user_id         String               @db.ObjectId
  name            String               // Ex: "CDB Inter 102%", "Ações Petrobras", "Tesouro IPCA 2029"
  type            String               // "fixed_income", "variable_income", "cripto", "others"
  ticker          String?              // Ex: "PETR4", "MXRF11", "BOVA11" (usado para cotação automática)
  quantity        Float?               // Quantidade de cotas/ações (usado para Renda Variável/Cripto)
  institution     String               // Ex: "Inter", "XP", "NuInvest"
  invested_amount Float                // Valor original total investido
  current_amount  Float                // Valor atualizado de mercado/cotação
  purchase_date   String               // Data de aquisição/início (YYYY-MM-DD)
  created_at      String?              @default("datetime('now')")
  updated_at      String?
  users           users                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  history         investment_history[]
  @@index([user_id])
}

model investment_history {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  user_id       String      @db.ObjectId
  investment_id String      @db.ObjectId
  date          String      // Snapshot mensal (Formato "YYYY-MM")
  invested_val  Float       // Valor investido acumulado no mês
  current_val   Float       // Valor atualizado acumulado no mês
  created_at    String?     @default("datetime('now')")
  investments   investments @relation(fields: [investment_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([investment_id])
}

model chat_messages {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String   @db.ObjectId
  sender     String   // "user" ou "assistant"
  text       String
  created_at String?  @default("datetime('now')")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
}
